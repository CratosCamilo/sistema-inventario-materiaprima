# ── Base de datos ────────────────────────────────────────────────────────────
# Local: dejar vacío → usa SQLite local (file:local.db en la raíz del proyecto)
# Producción Turso: poner la URL de tu base de datos en Turso
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# ── Autenticación ─────────────────────────────────────────────────────────────
# Secreto para firmar los JWT. Generar con: openssl rand -base64 32
JWT_SECRET=cambiar-en-produccion-usar-openssl-rand-base64-32
